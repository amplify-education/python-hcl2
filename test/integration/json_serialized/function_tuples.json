      "\"Octopus.Action.Aws.IamCapabilities\"": "${jsonencode([\"CAPABILITY_AUTO_EXPAND\", \"CAPABILITY_IAM\", \"CAPABILITY_NAMED_IAM\"])}"
     },
     "__is_block__": true
    }
   }
  }
 ],
 "variable": [
